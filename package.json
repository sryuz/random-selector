{
  "name": "random-selector",
  "version": "1.0.0",
  "description": "趣味随机选择器 - 帮助选择困难症做决定",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "deploy:gh": "node deploy-gh.js"
  },
  "keywords": [
    "random",
    "selector",
    "wheel",
    "decision"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.random-selector.app",
    "productName": "随机选择器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "assets/icons/icon.ico"
    }
  }
}
